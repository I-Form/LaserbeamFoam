FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      magperm;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../constant/properties_reference"
dimensions      [1 1 -2 0 0 0 0];

internalField   uniform 0.0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    leftWall
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_ga_;
    }

    rightWall
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_ga_;
    }

    lowerWall
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_ga_;
    }

    atmosphere
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_ga_;
    }

    defaultFaces
    {
        type            empty;
    }
}


