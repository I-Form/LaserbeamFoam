FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.air;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    leftWall
    {
        type            zeroGradient;
    }
    rightWall
    {
        type            zeroGradient;
    }

    lowerWall
    {
        type            zeroGradient;
    }

    atmosphere
    {
        type            inletOutlet; // <------ USE THIS but coded
        inletValue      uniform 0;//1;
        value           uniform 0;//1;

        // type            alphaContactAngle;
        // thetaProperties
        // {
        //     // oil             { theta0 90; }
        //     // water           { theta0 90; }
        //     // mercury         { theta0 90; }
        //     Fe              { theta0 90; }
        //     GaInSn          { theta0 90; }
        // }
        // value           uniform 0;
    }

    defaultFaces
    {
        type            empty;
    }
}


