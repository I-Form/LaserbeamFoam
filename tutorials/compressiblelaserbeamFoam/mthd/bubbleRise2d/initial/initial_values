Description:
    This is a dictionary made as a work-around to pyFoam ParsedParameter
    failing when a `$variable` is used.

    Instead, relevant dictionary variables are listed here; then imported
    using the `#include` directive
\*---------------------------------------------------------------------------*/
FoamFile
{
    format      ascii;
    class       dictionary;
    location    "initial";
    object      initial_values;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// User's Initial Value Defintions:
p_internal 1e5;
T_internal 293;
U_initial_vector_values (0 0 0);
B_target -99e-3;


// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - //
// Automated calculations for initial H vector values.
#include "../constant/properties_reference"

// Compute H for constant B initial conditions
// > `B = mu * H`, or $\vec{B} = \mu \, \vec{H}$.
H_argon_target  #calc "$B_target / $magnetic_permeability_argon_";
H_ga_target     #calc "$B_target / $magnetic_permeability_ga_";

// Note: `z` axis on 2D will result in solution singularity.
H_argon ($H_argon_target 0 0);
H_ga    ($H_ga_target    0 0); 

// hot fix
H_air $H_argon;
H_fe  $H_ga;

// ************************************************************************* //