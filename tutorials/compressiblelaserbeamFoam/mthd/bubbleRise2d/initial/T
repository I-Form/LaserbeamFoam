dimensions      [0 0 0 1 0 0 0];

internalField   uniform $T_internal; // 293;

boundaryField
{
    leftWall
    {
        type            fixedValue;
        value           $internalField;
        // type zeroGradient;

        // type            inletOutlet;
        // phi             rhoPhi;
        // inletValue      $internalField;
    }
    rightWall
    {
        type            fixedValue;
        value           $internalField;
        // type zeroGradient;
        // type outletInlet;
        // phi rhoPhi;
        // outletValue $internalField;
        // value
    }

    lowerWall
    {
        type            fixedValue;
        value           $internalField; //uniform 293;
    }
    atmosphere
    {
        type            inletOutlet;
        phi             rhoPhi;
        inletValue      $internalField;

        // type            fixedValue;
        // value           $internalField;
    }
    defaultFaces
    {
        type            empty;
    }
}


