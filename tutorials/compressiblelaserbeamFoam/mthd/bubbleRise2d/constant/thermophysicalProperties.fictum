FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties.fictum; //GaInSn;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          eConst;
    equationOfState perfectFluid; // rhoConst;perfectFluid; Boussinesq
    specie          specie;
    energy          sensibleInternalEnergy;
}
/* Citations: 
    [1] https://pubs.acs.org/doi/full/10.1021/je400882q (For all propreties*)
    [2] https://www.santechchem.com/introduction-of-galinstan-221.html (*For heat capcity, which is not listed)

    Note - it reports thermal conductivity to be 24.4 at 293 K; which is higher than online sources

    Setup notes:
    - `perfectFluid` is used to create artificial compressibility, and is used for compatability with argon
*/
#include "properties_reference"


// TREAT AS Ga-....
/*
rho0 6360
dyn_mu 2.18e-3
surfTens 533e-3
speedSound 2730
elec_cond 32900 * 1e2
Temp = 20 deg
*/
magnetic_permeability	$magnetic_permeability_ga_; // 1.256e-6;
elec_conductivity	    $elec_conductivity_ga_;     // 3.46e6;

TSolidus	1.0001;
TLiquidus	1.0; // Enforce liquid
LatentHeat	1.0;

// Unused: Latentheatgas 12.7;

mixture
{
    specie
    {
        // N/Req.
        molWeight   84.317125e-3; // kg/mol
    }
    equationOfState
    {   
        // constant
        rho         6360; // kg/m^3

        // // Perfect fluid
            rho0        6360; // kg/m^3
            R           1e6; // Artificial value to prevent stiffness
            // R           98.60941793441414; // Actual R value - invalid usage
        /*
        dx.doi.org/10.1021/je400882q
        equation (9) states

            rho = rho0 + (drho/dT)*(T-T_melt)
        - rho0 = 6580 kg/m^3 (at T = T_melt)
        - (drho/dT) = -7.76e-4 g.cm^(-3).K^(-1)

        Hence model is icoPolynomial
        */
        // rhoCoeffs<2> (6580.1512 -0.776); (must be of size 8, avoid)

        // Boussinesq ---------------------- //
            // beta    -0.0001220125786163522;
            // rho0    6360.0;
            // T0      283.7;
    }
    thermodynamics
    {
        Cv          3537; // (original 3.536 J cm^(-3) K^(-1))
        Hf          0;

        Cp          296;
    }
    transport
    {
        mu          2.18e-3; 
        Pr          0.026445901639344266; // manually calculated

        // kappa       24.4; // W / (m . K)

        /*
        Assumed constant, I believe linearly extrapolated from T:(299,307)
        */
    }
    
    Tvap 1e+32;
}



// viscosityModel constant;

// nu [0 2 -1 0 0 0 0] 2.5e-06;
// rho [1 -3 0 0 0 0 0] 7874;
// kappa [1 1 -3 -1 0] 75.0;
// kappasolid [1 1 -3 -1 0] 60.0;
// Cp [0 2 -2 -1 0] 820;
// Cpsolid [0 2 -2 -1 0] 450.0;
// Tsolidus [0 0 0 1 0] 1790;
// Tliquidus [0 0 0 1 0] 1840;
// Tvap [0 0 0 1 0] 3134.0;
// Latentheatgas [0 2 -2 0 0] 6.09e6;
// Latentheat [0 2 -2 0 0] 270000;
// beta [0 0 0 -1 0] 5.0e-6;
// molarmass [1 0 0 0 -1] 0.055;
// elec_resistivity [1 3 -3 0 0] 1.0e-6;
// e_num_density [0 -3 0 0 0] 3.83e29;
// v_rate [0 1 0 0 0] 1e-2;



