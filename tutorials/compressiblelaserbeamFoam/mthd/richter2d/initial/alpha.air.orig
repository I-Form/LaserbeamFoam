FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.air;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    leftWall
    {
        type            alphaContactAngle;
        thetaProperties
        (
            ( fictum air ) 90 0 0 0
        );
        value           uniform 0;


        // type zeroGradient;
        
        // type            inletOutlet; // <------ USE THIS but coded
        // inletValue      uniform 1;
        // value           uniform 0;
    }
    rightWall
    {
        type            alphaContactAngle;
        thetaProperties
        (
            ( fictum air ) 90 0 0 0
        );
        value           uniform 0;
        // type            alphaContactAngle;
        // thetaProperties
        // {
        //     // oil             { theta0 90; }
        //     // water           { theta0 90; }
        //     // mercury         { theta0 90; }
        //     Fe              { theta0 90; }
        //     fictum          { theta0 90; }
        //     fictumvapour          { theta0 90; }
        // }
        // value           uniform 0;
        // type zeroGradient;

        // type            inletOutlet; // <------ USE THIS but coded
        // inletValue      uniform 0;
        // value           uniform 0;
    }

    inlet
    {
        // type inletOutlet;
        // inletValue uniform 1;
        // value uniform 1;
        $leftWall ;
    }

    outlet
    {
        // type inletOutlet;
        // inletValue uniform 1;
        // value uniform 1;

        $rightWall ;
    }

    lowerWall
    {
        type            alphaContactAngle;
        thetaProperties
        (
            ( fictum air ) 90 0 0 0
        );
        value           uniform 0;
    }
    atmosphere
    {
        type            inletOutlet; // <------ USE THIS but coded
        inletValue      uniform 0;//1;
        value           uniform 0;//1;

        // type            alphaContactAngle;
        // thetaProperties
        // {
        //     // oil             { theta0 90; }
        //     // water           { theta0 90; }
        //     // mercury         { theta0 90; }
        //     Fe              { theta0 90; }
        //     fictum          { theta0 90; }
        // }
        // value           uniform 0;
    }
    defaultFaces
    {
        type            empty;
    }
}


