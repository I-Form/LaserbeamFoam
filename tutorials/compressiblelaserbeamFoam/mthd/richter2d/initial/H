        type            fixedValue;
        value           uniform $H_fe ;
    }
    atmosphere
    {
        type            fixedValue;
        value           uniform $H_fe ; //; (0 0 40207.00637); //402070.0637);
    }
    rightWall
    {
        type            zeroGradient; // empty;
        // type            fixedValue;
        // value           uniform $H_fe;
    }
    leftWall
    {
        type            zeroGradient; // empty;
        // type            fixedValue;
        // value           uniform $H_fe;
    }

    inlet
    {
        $rightWall
    }
    outlet
    {
        $rightWall
    }

