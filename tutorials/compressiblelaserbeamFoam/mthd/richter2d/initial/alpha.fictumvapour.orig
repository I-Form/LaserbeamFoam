FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.GaInSn;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    leftWall
    {
        type            zeroGradient;
    }
    rightWall
    {
        type            zeroGradient;
    }

    inlet
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }

    lowerWall
    {
        type            zeroGradient;
    }

    atmosphere
    {
        type            inletOutlet;
        
        inletValue      uniform 0;
        value           uniform 0;
    }
    
    defaultFaces
    {
        type            empty;
    }
}


// ************************************************************************* //
