    class       dictionary;
    location    "constant";
    object      flow_region_geom;
}
/*
    Geometry parameters which are shared across
    multiple dictionaries.
*/
xmin_value                  -35e-3;
xmax_value                  35.0e-3;

ymin_value                  0;
