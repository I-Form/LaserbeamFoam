#include "flow_region_geom"

scale 1;

/*
    x -- flow wise
    y -- tangent


    |
    | --> flow
    |

   y^
    |___> x
*/
xmin $xmin_value ;
xmax $xmax_value ;
ymin $ymin_value ;
ymax $ymax_value ;
zmin 0;
zmax 10.1e-3;

y_inlet_min $L0value;
y_inlet_max $L1value;

y_outlet_min $y_inlet_min;
y_outlet_max $y_inlet_max;

vertices        
(
    ($xmin  $ymin  $zmin) // 0
    ($xmax  $ymin  $zmin) // 1
    ($xmax  $ymax  $zmin) // 2
    ($xmin  $ymax  $zmin) // 3
    // - - - - - - - - - - - -
    ($xmin  $ymin  $zmax) // 4
    ($xmax  $ymin  $zmax) // 5
    ($xmax  $ymax  $zmax) // 6
    ($xmin  $ymax  $zmax) // 7

    // //// Inlet/Outlet stream
    // // front face:
    // ($xmin $y_inlet_min $zmin) // 8
    // ($xmax $y_inlet_min $zmin) // 9
    // ($xmax $y_inlet_max $zmin) // 10
    // ($xmin $y_inlet_max $zmin) // 11
    // // rear face:
    // ($xmin $y_inlet_min $zmax) // 12
    // ($xmax $y_inlet_min $zmax) // 13
    // ($xmax $y_inlet_max $zmax) // 14
    // ($xmin $y_inlet_max $zmax) // 15
);

dx #calc "(20.0e-3)/40.0"; // orig: 4.0/40.0   "(10.0e-3)/40.0"
nx #calc "abs(($xmax - $xmin) / $dx)";
ny #calc "abs(($ymax - $ymin) / $dx)";

ny_wallzone_lower #calc   "abs(($y_inlet_min - $ymin) / $dx)";
ny_wallzone_upper #calc   "abs(($ymax - $y_inlet_max) / $dx)";

ny_flowzone #calc "abs(($y_inlet_max - $y_inlet_min) / $dx)";

