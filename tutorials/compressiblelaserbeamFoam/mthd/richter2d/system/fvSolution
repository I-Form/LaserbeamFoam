FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

std_tol 1e-6;
final_tol 1e-7;

solvers
{
    "alpha.*"
    {
        nAlphaSubCycles 4;
        cAlpha          1;
        tolerance 1e-12;
    }

    "pcorr.*"
    {
        solver          PCG;
        preconditioner
        {
            preconditioner  GAMG;
            tolerance       $std_tol;
            relTol          0.05;
            smoother        GaussSeidel;
        }
        tolerance       $std_tol;
        relTol          0;
        maxIter         1000;
    }

    ".*(rho|rhoFinal)"
    {
        solver          diagonal;
    }

    p_rgh
    {
        solver          GAMG;
        tolerance       $std_tol;
        relTol          0.0;
        smoother        GaussSeidel;
    }

    p_rghFinal
    {
        solver          PCG;
        preconditioner
        {
            preconditioner  GAMG;
            tolerance       $final_tol;
            relTol          0;
            nVcycles        5;
            smoother        GaussSeidel;
        }
        tolerance       $final_tol;
        relTol          0;
        maxIter         2000;
    }

    "(U|T|k|B|nuTilda)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-012;
        relTol          0.0;
        nSweeps         1;
    }

    "(U|T|k|B|nuTilda)Final"
    {
        $U;
        relTol          0;
    }

    // ----------------------------------------------------------------------------- //
    H
    {
        /*
        solver          smoothSolver;
        smoother        GaussSeidel;//GaussSeidel;//DICGaussSeidel;//
        tolerance       1e-09;
        relTol          0.0;//0.1;
        nSweeps         2;//1;
        maxIter         5000;
        */
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       $std_tol;
        minIter         1;
        maxIter         500;//2


    }

    HFinal
    {
        $H;
        tolerance       $final_tol;
        relTol          0;
    }

    pH
    {
        /*
        $p_rgh;
        tolerance       $std_tol;
        relTol          0.0;
        maxIter         5000;
        */
        solver          PCG;
        preconditioner  DIC;
        tolerance       $std_tol;
        relTol          0.0;

    }

    pHFinal
    {
        $pH;
        relTol          0;
    }
}

// PIMPLE
// {
//     nOuterCorrectors 1;//always 1
//     nCorrectors     5;
//     nNonOrthogonalCorrectors 0;
// }

relaxationFactors
{
    equations
    {
        ".*"            1;
    }
}

// -----
MELTING
{
    minTempCorrector 1;
    maxTempCorrector 50;    //20;
    epsilonTolerance 1e-12; //1e-9;
    epsilonRelaxation 0.9;
}



PIMPLE
{
    nOuterCorrectors            1; //1;      // always 1
    nCorrectors                 4; // 15;      // 50; // must be >= to nMaxIter in piso
    nNonOrthogonalCorrectors    0;//is uniform      // 0;
}


    piso_residual_control
    {
        // - - Mandatory - - //             (some will default)
        abs_tolerance               1e-11;   // set high to "disable"
        rel_tolerance               100; // 0.001e-2;   // set high to "disable"
        nMaxIter                    50;     // 0 for simple
        nMinIter                    3;      //

        // - - Optionals - - //
        enable_tracker              true;
    }

    piso_residual_improvement
    {   
        // - - Mandatory - - //  
        // Fail Counters
        nMaxIter                    2;      // (should be less than nMaxIter in residuals)
        nMinIter                    0;      // Always 0; is redundant (will be removed in future)
        
        // Absolute and Relative Change Tolerances
        abs_tolerance               1e-9; //12e-12;  // Set to `0` to disable (or `-1` ?)
        rel_tolerance               0.02; //2e-4;   // Set to `0` to disable
        
        // - - Optionals - - //
        enable_tracker              true;
    }


BPISO
{
    nOuterCorrectors            1;      // always 1 
    nCorrectors                 5;//7;     // must be >= to nMaxIter in piso
    nNonOrthogonalCorrectors    0;//isuniform 1;//1;      // 1;
    pRefCell                    0;
    pRefValue                   0.0;
}

    bpiso_residual_control
    {
        // - - Mandatory - - //             (some will default)
        abs_tolerance               5e-11;  // set high to "disable"
        rel_tolerance               100;     // set high to "disable"
        nMaxIter                    50;     // 0 for simple
        nMinIter                    3;      //

        // - - Optionals - - //
        enable_tracker              true;
    }

    bpiso_residual_improvement
    {
        // - - Mandatory - - //  
        // Fail Counters
        nMaxIter                    3;      // (should be less than nMaxIter in residuals)
        nMinIter                    0;      // Always 0; is redundant (will be removed in future)
        
        // Absolute and Relative Change Tolerances
        abs_tolerance               1e-12;  // Set to `0` to disable (or `-1` ?)
        rel_tolerance               2e-4;   // Set to `0` to disable
        
        // - - Optionals - - //
        enable_tracker              true;
    }

