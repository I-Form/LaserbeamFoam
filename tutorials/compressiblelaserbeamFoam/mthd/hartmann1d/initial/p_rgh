FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// #include "../system/flow_region_geom"

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1e5;

boundaryField
{
    inlet
    {
        type            totalPressure;
        p0              uniform 1e5;    
    }

    outlet
    {
        type            totalPressure;
        p0              uniform 99999.0; // i.e., 1e5 - 1
    }

    lowerWall
    {
        type            fixedFluxPressure;
        value           $internalField;
    }

    upperWall
    {
        type            fixedFluxPressure;
        value           $internalField;
    }

    defaultFaces
    {
        type            empty;
    }
}

