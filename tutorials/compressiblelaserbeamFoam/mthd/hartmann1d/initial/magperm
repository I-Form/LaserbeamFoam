FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      magperm;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../constant/properties_reference"
dimensions      [1 1 -2 0 0 0 0];

internalField   uniform 0.0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_air_;
    }

    outlet
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_air_;
    }

    lowerWall
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_air_;
    }

    upperWall
    {
        type            fixedValue;
        value           uniform $magnetic_permeability_air_;
    }

    defaultFaces
    {
        type            empty;
    }
}


