FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      H;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "initial_values"
dimensions      [0 -1 0 0 0 0 0];

internalField uniform $H_air ; //(0 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"
    lowerWall
    {
        type            fixedValue;
        value           uniform $H_air;
    }
    upperWall
    {
        type            fixedValue;
        value           uniform $H_air;
    }
    outlet
    {
        type            zeroGradient;
    }
    inlet
    {
        type            zeroGradient;
    }

    // note: front/back
    // {
    //     type            zeroGradient;
    // }

    defaultFaces
    {
        type            empty;
    }
}


